# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
insert_final_newline = true
end_of_line = lf
indent_style = space
indent_size = 4
max_line_length = 80

[*.html]
indent_size = 2

[Makefile]
indent_style = space

# Matches the exact files either package.json or .travis.yml
[{package.json,.yml}]
indent_size = 2
